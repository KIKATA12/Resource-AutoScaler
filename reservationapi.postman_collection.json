{
  "info": {
    "name": "Reservation API",
    "description": "Postman collection for the reservationapi REST endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Request Connection",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/request?clientId=client1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "request"
          ],
          "query": [
            {
              "key": "clientId",
              "value": "client1"
            }
          ]
        }
      }
    },
    {
      "name": "Release Connection",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/release",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "release"
          ]
        }
      }
    },
    {
      "name": "Status",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "status"
          ]
        }
      }
    },
    {
      "name": "Queue",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/queue",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "queue"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}
